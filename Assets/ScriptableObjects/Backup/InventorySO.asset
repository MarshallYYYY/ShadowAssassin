  Items:
  - Id: 0
    Name: "\u5B9D\u77F3"
    Description: "\u4E00\u9897\u78A7\u84DD\u8272\u7684\u5B9D\u77F3\uFF0C\u5185\u90E8\u6D8C\u52A8\u7740\u6E29\u67D4\u7684\u5149\u8292\uFF0C\u636E\u8BF4\u662F\u4ECE\u5939\u7F1D\u4E4B\u95F4\u7684\u6D41\u661F\u788E\u7247\u4E2D\u91C7\u51FA\u3002\u53EF\u7528\u4E8E\u5F3A\u5316\u88C5\u5907\uFF0C\u5524\u9192\u5176\u4E2D\u6C89\u7761\u7684\u529B\u91CF\u3002"
    Sprite: {fileID: 21300000, guid: 3efc58e94a7a2df41886f4b40125bbb2, type: 3}
  - Id: 1
    Name: "\u91D1\u8272\u77FF\u77F3"
    Description: "\u4E00\u5757\u88AB\u91D1\u8272\u77FF\u8109\u8D2F\u7A7F\u7684\u77FF\u77F3\uFF0C\u5165\u624B\u6E29\u70ED\uFF0C\u4EFF\u4F5B\u5185\u90E8\u4ECD\u5728\u71C3\u70E7\u3002\u5DE8\u4EBA\u5320\u4EBA\u66FE\u8A00\uFF1A\u4E00\u5C0F\u5757\u4FBF\u80FD\u8BA9\u4E00\u67C4\u51E1\u94C1\u5251\u8FDB\u5316\u4E3A\u4F20\u4E16\u540D\u5251\u3002"
    Sprite: {fileID: 21300000, guid: 262701d510e2d524c9a5d17b634b5438, type: 3}
  - Id: 2
    Name: "\u94F6\u8272\u77FF\u77F3"
    Description: "\u8FD9\u5757\u77FF\u77F3\u5728\u6F06\u9ED1\u4E2D\u4ECD\u6563\u53D1\u7740\u67D4\u548C\u7684\u6708\u5149\u822C\u5149\u6CFD\u3002\u9576\u5D4C\u5728\u76D4\u7532\u4E0A\u80FD\u62B5\u5FA1\u8BC5\u5492\u4E0E\u9ED1\u9B54\u6CD5\uFF0C\u662F\u6DF1\u5165\u5730\u4E0B\u57CE\u5821\u7684\u5192\u9669\u8005\u5FC5\u5907\u4E4B\u7269\u3002"
    Sprite: {fileID: 21300000, guid: 41e566ce27dfa4043a6a1de57186ae84, type: 3}
  - Id: 3
    Name: "\u9ED1\u8272\u77FF\u77F3"
    Description: "\u4E00\u5757\u5D29\u88C2\u7684\u7EAF\u9ED1\u77FF\u77F3\uFF0C\u4E3E\u5728\u5149\u4E0B\u5374\u50CF\u628A\u5149\u7ED9\u5438\u8FDB\u53BB\u4E86\u3002\u636E\u8BF4\u662F\u5728\u53E4\u795E\u6B7B\u6218\u7684\u6DF1\u6E0A\u4E2D\u7194\u94F8\u800C\u6210\uFF0C\u80FD\u8BA9\u6B66\u5668\u950B\u5229\u5230\u8D85\u4E4E\u5E38\u7406\uFF0C\u4F46\u7ECF\u624B\u7684\u5320\u4EBA\u5F80\u5F80\u518D\u4E5F\u7761\u4E0D\u5B89\u7A33\u3002"
    Sprite: {fileID: 21300000, guid: 845a5007f0d458c4ca8c663b2634149d, type: 3}
  - Id: 4
    Name: "\u68EE\u6797\u85E4\u8513"
    Description: "\u4E00\u6761\u97E7\u6027\u5341\u8DB3\u7684\u85E4\u8513\uFF0C\u5F2F\u66F2\u5982\u540C\u874E\u4F0F\u7684\u7075\u86C7\uFF0C\u91C7\u81EA\u4F1A\u8BF4\u8BDD\u7684\u5618\u8BED\u4E4B\u6797\u3002\u7528\u5B83\u7F20\u7ED5\u5251\u67C4\u80FD\u589E\u5F3A\u63E1\u529B\uFF0C\u7F1D\u5408\u5728\u76D4\u7532\u4E0A\u80FD\u8D4B\u4E88\u5B83\u751F\u547D\u822C\u7684\u67D4\u97E7\uFF0C\u5B9B\u5982\u68EE\u6797\u81EA\u8EAB\u5728\u5B88\u62A4\u7740\u7A7F\u6234\u8005\u3002"
    Sprite: {fileID: 21300000, guid: 00d80d042e55779409008e05d607cc8c, type: 3}
